# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
tfplan
tfplan.binary
**/plans/
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Block all .tfvars by default (may contain secrets)
*.tfvars
*.tfvars.json

# Whitelist only the non-sensitive config tfvars
!envs/au-dev/terraform.tfvars
!envs/au-prod/terraform.tfvars
!envs/us-prod/terraform.tfvars

# Secrets - never commit these
.env
.env.*
.env.local
.env.production
*.credentials
**/credentials.json
**/access-keys*
**/.aws/

# SSH keys / TLS certs
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
id_rsa
id_ed25519
*.pub

# Kubernetes secrets
*-secret.yaml
*-credentials.yaml
kubeconfig
kubeconfig.*
.kube/
.docker/config.json

